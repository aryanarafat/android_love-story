<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.LoveStory" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">#F9F9F9</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>









    <style name="TitleBarTextAppearance" parent="android:TextAppearance">
        <item name="android:fontFamily">@font/solaimanlipi</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@android:color/black</item>
    </style>

    <style
        name="BottomNavigationStyle" parent="Widget.Design.BottomNavigationView">
        <!--
            <item name="android:foreground">@drawable/ripple_custom</item>-->
        <!--<item name="itemBackground">@drawable/ripple_custom</item>-->
        <item name="itemIconTint">@color/bottom_navigation_color</item>
        <item name="itemTextColor">@color/bottom_navigation_color</item>

        <!--        <item name="android:fontFamily">@font/varela_round</item>-->

    </style>



    <style name="DialogThemelight" parent="ThemeOverlay.AppCompat.Dialog.Alert">
        <item name="android:background">#FFFFFF</item>
        <item name="android:textSize">16sp</item>
        <item name="fontFamily">@font/solaimanlipi</item>
        <item name="android:textColorPrimary">#000000</item>
        <item name="colorAccent">#A81425</item>
        <item name="cornerRadius">10dp</item>
    </style>

    <style name="DialogThemeDark" parent="Theme.AppCompat.Dialog.Alert" >
        <item name="android:background">#171717</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">16sp</item>
        <item name="fontFamily">@font/solaimanlipi</item>
        <item name="android:textColorPrimary">#FFFFFF</item>

    </style>
</resources>