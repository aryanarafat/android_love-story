<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/item"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:orientation="horizontal"

    android:layout_marginTop="10dp"

    android:background="@drawable/adapter_background"
    android:layout_height="wrap_content">




    <LinearLayout
        android:id="@+id/linear1"
        android:layout_weight="1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"
        android:layout_marginTop="3dp"
        android:layout_marginRight="5dp"
        android:layout_marginBottom="3dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="5dp">

        <LinearLayout
            android:id="@+id/linear_circle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/linear_circle"
            android:gravity="center"
            android:orientation="vertical"
            >

            <ImageView
                android:id="@+id/icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:src="@drawable/bottom_nav_menu_history"
                android:textColor="#ffffff"
                android:textSize="16sp" />
        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/linear3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingLeft="5dp"
            android:paddingRight="5dp">



            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="vertical">



                <TextView
                    android:id="@+id/adapter_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/fonts"
                    android:maxLines="1"
                    android:paddingLeft="5dp"
                    android:layout_weight="1"
                    android:paddingRight="5dp"
                    android:text="Titel Textview"
                    android:textColor="#424242"
                    android:textSize="18sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />


                <TextView
                    android:layout_weight="1"
                    android:id="@+id/category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/solaimanlipi"
                    android:paddingLeft="5dp"
                    android:paddingRight="5dp"
                    android:text="category"
                    android:textColor="#616161"
                    android:textSize="14sp"
                    app:layout_constraintTop_toBottomOf="@+id/adapter_title"
                    />

            </LinearLayout>


            <TextView
                android:id="@+id/time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="bottom"
                android:maxLines="1"
                android:textSize="12sp"
                android:layout_marginRight="5dp"
                android:text="time"
                android:textColor="#616161"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>





        <ImageView
            android:id="@+id/del"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:src="@drawable/delete_grey"
            android:text="delete">

        </ImageView>

    </LinearLayout>





</LinearLayout>